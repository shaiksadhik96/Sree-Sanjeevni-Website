# Server Configuration
PORT=5000
NODE_ENV=development

# Database Configuration
MONGODB_URI=mongodb://localhost:27017/sreesanjeevni_Data

# JWT Secret (Change this to something secure)
JWT_SECRET=your_super_secret_key_12345

# Email Configuration (for notifications)
# Use Gmail or any SMTP service
# For Gmail: Enable 2-factor auth and generate an "App Password"
# Go to: https://myaccount.google.com/apppasswords
EMAIL_USER=your-email@gmail.com
EMAIL_PASSWORD=your-app-password-here
ADMIN_EMAIL=admin@sreesanjeevni.com

# How to setup Gmail App Password:
# 1. Go to your Google Account
# 2. Enable 2-Step Verification
# 3. Go to Security > 2-Step Verification > App passwords
# 4. Generate a new app password for "Mail"
# 5. Copy the 16-character password and paste it as EMAIL_PASSWORD
